{
  "name": "drift",
  "private": true,
  "bin": {
    "drift": "dist/main.js"
  },
  "type": "module",
  "module": "index.ts",
  "scripts": {
    "drift": "bun run src/cli/main.ts",
    "drift:run": "bun run src/cli/main.ts run",
    "drift:plan": "bun run src/cli/main.ts plan",
    "drift:commit": "bun run src/cli/main.ts commit",
    "drift:edit": "bun run src/cli/main.ts edit",
    "drift:new": "bun run src/cli/main.ts new",
    "drift:init": "bun run src/cli/main.ts init",
    "drift:assemble": "bun run src/cli/main.ts assemble",
    "build": "bun run build.ts",
    "server": "bun run src/server/index.ts",
    "ui": "bun src/ui/index.html",
    "test": "bun test",
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "lint:ast-grep:test": "ast-grep test --config .ast-grep/sgconfig.yml --skip-snapshot-tests",
    "lint:ast-grep": "ast-grep scan --config .ast-grep/sgconfig.yml src --error",
    "lint:effect": "ast-grep scan --config .ast-grep/sgconfig.yml src --error --filter 'no-(async-await|try-catch|throw|promise-type|any|require)'",
    "format": "oxfmt . --write",
    "format:check": "oxfmt . --check",
    "check": "bun run lint:ast-grep:test && bun run lint:effect && bun run lint:ast-grep && bun run lint && bun run format:check && bun run typecheck"
  },
  "dependencies": {
    "@effect/language-service": "^0.73.1",
    "effect": "^3.19.16",
    "esrap": "^2.2.3",
    "svelte": "5"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@typescript/native-preview": "^7.0.0-dev.20260210.1",
    "bun-plugin-svelte": "^0.0.6",
    "oxfmt": "^0.28.0",
    "oxlint": "^1.43.0"
  }
}
